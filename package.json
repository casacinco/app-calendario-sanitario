{
  "name": "app-calendario-sanitario",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
